{
  "name": "Wire Server",
  "image": "mcr.microsoft.com/devcontainers/base:debian",
  
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {}
  },

  "onCreateCommand": "nix profile install nixpkgs#direnv && echo 'eval \"$(direnv hook bash)\"' >> ~/.bashrc",
  "postCreateCommand": "direnv allow",

  "customizations": {
    "vscode": {
      "extensions": [
        "haskell.haskell",
        "jnoortheen.nix-ide"
      ],
      "settings": {
        "haskell.manageHLS": "PATH"
      }
    }
  }
}
