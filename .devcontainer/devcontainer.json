{
  "name": "Wire Server",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  
  "features": {
    "ghcr.io/devcontainers/features/nix:1": {
      "extraNixConfig": "experimental-features = nix-command flakes",
      "packages": "direnv"
    }
  },

  "postCreateCommand": "direnv allow",

  "customizations": {
    "vscode": {
      "extensions": [
        "haskell.haskell",
        "jnoortheen.nix-ide"
      ],
      "settings": {
        "haskell.manageHLS": "PATH"
      }
    }
  }
}
