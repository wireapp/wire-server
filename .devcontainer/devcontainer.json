{
  "name": "Wire Server",
  "image": "nixos/nix:latest",
  
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "vscode"
    }
  },

  "onCreateCommand": "nix profile install nixpkgs#direnv && echo 'eval \"$(direnv hook bash)\"' >> ~/.bashrc",
  "postCreateCommand": "direnv allow",

  "customizations": {
    "vscode": {
      "extensions": [
        "haskell.haskell",
        "jnoortheen.nix-ide"
      ],
      "settings": {
        "haskell.manageHLS": "PATH"
      }
    }
  },

  "remoteUser": "vscode"
}
