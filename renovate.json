{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "separateMajorMinor": true,
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "minimumReleaseAge": "3 days",
  "packageRules": [
    {
      "enabled": false,
      "matchUpdateTypes": [
        "major"
      ]
    },
    {
      "enabled": true,
      "matchUpdateTypes": [
        "minor",
        "patch"
      ]
    },
    {
      "enabled": true,
      "matchUpdateTypes": [
        "security"
      ],
      "prPriority": 100,
      "prConcurrentLimit": 0,
      "prHourlyLimit": 0
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "osvVulnerabilityAlerts": true
}
